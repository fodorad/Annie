# Copy this file to .env and fill in your values, then run: make docker-run
# .env is gitignored — your data paths stay local.

# Port exposed on the host machine.
ANNIE_PORT=8080

# Host directory for Annie state (logs, session DBs, render cache, configs).
# Defaults to ./annie-home/ next to docker-compose.yml if not set.
# Use an absolute path so the folder is easy to find in Finder / Explorer.
# ANNIE_HOME_HOST=/Users/yourname/.annie-docker

# ── Data directories (uncomment and set to enable each source) ────────────────

# ANNIE_VIDEO_DIR=/Volumes/MyDrive/video
# ANNIE_VDET_DIR=/Volumes/MyDrive/vdet
# ANNIE_TRACK_DIR=/Volumes/MyDrive/track

# Optional label CSV seeded as a label source on startup.
# ANNIE_LABEL_CSV=/Volumes/MyDrive/label.csv
# ANNIE_LABEL_KEY=video_id
# ANNIE_LABEL_VALUES=subset,openness,conscientiousness

# Directory that contains the protagonist CSV (needs write access for Export).
# ANNIE_PROTAGONIST_DIR=/Volumes/MyDrive/annotations

# Filename of the protagonist CSV inside ANNIE_PROTAGONIST_DIR.
# ANNIE_PROTAGONIST_CSV_NAME=protagonist_track_heuristic.csv
